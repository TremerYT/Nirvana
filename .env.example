# Database Configuration
DATABASE_URL=

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_BASE_URL=http://localhost:3000/api

# Email Service (for OTP, password reset, etc.)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@nirvana.com

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# OAuth Providers (Google, etc.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMS Service (for OTP via SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis (for session storage, caching)
REDIS_URL=

# File Upload (AWS S3, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Application Settings
NODE_ENV=development
PORT=3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
